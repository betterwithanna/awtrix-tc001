# =====================================================================
# AWTRIX TC001 -- Konfiguration
# Kopiere diese Datei nach ".env" und trage deine Werte ein.
# Die .env wird NICHT eingecheckt (siehe .gitignore).
# =====================================================================

# --- Modus -----------------------------------------------------------
MODE=mqtt                 # mqtt = ueber Broker (ohne PC) | http = lokal an die Uhr-IP
PREFIX=awx_anna_q7v3      # MQTT-Prefix, IDENTISCH in der Uhr eingestellt.
                          # Bei oeffentlichem Broker: nicht erratbar waehlen (Schutz!).

# --- HTTP-Modus: lokale IP der Uhr -----------------------------------
AWTRIX_IP=192.168.8.34

# --- MQTT-Modus: Broker ----------------------------------------------
# AWTRIX 0.98 kann nur unverschluesseltes MQTT (kein TLS) und hat ein kurzes
# Username-Feld -> oeffentlicher Broker ohne Login funktioniert zuverlaessig.
MQTT_HOST=broker.emqx.io
MQTT_PORT=1883
MQTT_USER=                # leer = anonym (broker.emqx.io braucht keinen Login)
MQTT_PASS=
MQTT_TLS=false

# --- Instagram Graph API ---------------------------------------------
IG_AUTH=instagram         # instagram (Instagram Login) | facebook (ueber FB-Seite)
IG_TOKEN=
IG_USER_ID=
IG_API_VERSION=v21.0

# --- Anzeige (optional) ----------------------------------------------
EUR_SIGN=EUR              # Waehrungszeichen fuer die (spaetere) Einnahmen-App
IG_ICON=                  # ID/Name eines hochgeladenen 8x8-AWTRIX-Icons (optional)

# --- Mailing (Supabase) ----------------------------------------------
# Kontaktzahl via RPC awtrix_contacts_count. Publishable Key ist oeffentlich-
# sicher (RLS aktiv). Leer lassen = Mailing-Feld wird uebersprungen.
SUPABASE_URL=
SUPABASE_KEY=

# --- YouTube (Abonnenten) --------------------------------------------
# Data API v3 Key (geheim halten) + Kanal-ID (UC...). Leer = Feld uebersprungen.
YT_API_KEY=
YT_CHANNEL_ID=

# --- Token-Verlaengerung (nur fuer refresh_token.py) -----------------
FB_APP_ID=
FB_APP_SECRET=
